# Chemin vers un clone local de BCQuality (priorité 1).
# Pointez ici si vous avez un fork avec une couche /custom/.
# BCQUALITY_REPO_PATH=D:\forks\BCQuality

# URL pour clonage automatique si aucun chemin n'est fourni.
# BCQUALITY_REPO_URL=https://github.com/microsoft/BCQuality.git

# Cache local (Windows: %LOCALAPPDATA%\bcquality\cache, Unix: ~/.cache/bcquality).
# BCQUALITY_CACHE_PATH=

# Couches activées, par ordre de précédence croissante.
# BCQUALITY_LAYERS=microsoft,community,custom

# Cloner automatiquement le repo si aucun clone n'est trouvé.
# BCQUALITY_AUTO_CLONE=true
